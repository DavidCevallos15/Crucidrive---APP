# ─── CruciDrive — Variables de Entorno del Frontend ──────────
# Copia este archivo como .env y completa los valores.
# IMPORTANTE: Nunca subas el archivo .env al repositorio.

# URL del proyecto de Supabase
EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anónima de Supabase (NO la clave de servicio)
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL base del servidor Express (backend)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# URL del servidor de WebSockets (generalmente igual al backend)
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
